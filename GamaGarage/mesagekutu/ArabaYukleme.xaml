<Window x:Class="GamaGarage.mesagekutu.ArabaYukleme"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Giriş Paneli" Height="320" Width="460"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">

    <Border CornerRadius="25" BorderBrush="White" BorderThickness="3">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="OrangeRed" Offset="0.0"/>
                <GradientStop Color="LightGray" Offset="0.5"/>
                <GradientStop Color="SteelBlue" Offset="1.0"/>
            </LinearGradientBrush>
        </Border.Background>

        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                <materialDesign:PackIcon Kind="CheckCircle" Width="30" Height="30" Foreground="White" VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtABaslik" Text="GİRİŞ BAŞARILI" FontSize="18" FontWeight="Black" Foreground="White" Margin="10,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>

            <Border Grid.Row="1" Background="#44FFFFFF" CornerRadius="15" BorderBrush="#66FFFFFF" BorderThickness="1" Padding="10">
                <Grid>
                    <TextBlock x:Name="TxtAMesaj" Text="Giriş Yapılıyor..." 
                               Foreground="Black" FontSize="14" FontWeight="Bold" 
                               TextAlignment="Center" VerticalAlignment="Top" Margin="0,10,0,0"/>

                    <Canvas Height="190" VerticalAlignment="Bottom" ClipToBounds="True">
                        <Image x:Name="ArabaResmi" Source="/Assets/araba.png"  Width="250" Height="250"   Canvas.Top="-20">
                            <Image.RenderTransform>
                                <TranslateTransform x:Name="ArabaHareket" X="-250"/>
                            </Image.RenderTransform>
                        </Image>
                    </Canvas>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
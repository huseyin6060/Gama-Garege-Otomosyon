<Window x:Class="GamaGarage.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Gama Garage | Yönetim Paneli" Height="850" Width="1300"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        WindowStyle="None"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <Grid>
        <Grid.Background>
            <LinearGradientBrush x:Name="AnaGradyanFirca" StartPoint="0,0" EndPoint="1,1">
                <GradientStop x:Name="AnaStop1" Color="OrangeRed" Offset="0.0"/>
                <GradientStop x:Name="AnaStop2" Color="LightGray" Offset="0.5"/>
                <GradientStop x:Name="AnaStop3" Color="SteelBlue" Offset="1.0"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Margin="12" CornerRadius="25" Background="#44FFFFFF" BorderBrush="#66FFFFFF" BorderThickness="1">
            <Grid Width="210">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,25,0,10" HorizontalAlignment="Center">
                    <TextBlock x:Name="txtSaat" FontSize="28" FontWeight="Bold" Foreground="White" TextAlignment="Center">
                        <TextBlock.Effect>
                            <DropShadowEffect BlurRadius="5" ShadowDepth="2" Opacity="0.5"/>
                        </TextBlock.Effect>
                    </TextBlock>
                    <TextBlock x:Name="txtTarih" FontSize="12" FontWeight="SemiBold" Foreground="#EEE" TextAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>


              



                <StackPanel Grid.Row="1" Margin="0,10,0,10">
                    <Ellipse x:Name="ellFoto" Width="80" Height="80" Stroke="SteelBlue" StrokeThickness="4" HorizontalAlignment="Center">
                        <Ellipse.Fill>
                            <ImageBrush x:Name="imgGFoto" Stretch="UniformToFill"/>
                        </Ellipse.Fill>
                    </Ellipse>

                    <TextBlock x:Name="txtAdSoyad" 
                               Text="KULLANICI" 
                               HorizontalAlignment="Center" 
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Margin="10,10,10,5" 
                               FontSize="16" 
                               FontWeight="Black" 
                               Foreground="White"/>

                    <Separator Margin="40,5" Background="White" Opacity="0.3"/>
                </StackPanel>

                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="PnlMenu" Margin="5,0,5,10" VerticalAlignment="Top">
                        <Button x:Name="BtnPersonel" Click="BtnPersonel_Click" Style="{StaticResource MaterialDesignRaisedButton}" Height="50" Width="185" materialDesign:ButtonAssist.CornerRadius="20" Margin="0,2" Background="SteelBlue" BorderBrush="Transparent">
                            <StackPanel Orientation="Horizontal" Width="140">
                                <materialDesign:PackIcon Kind="AccountGroup" Width="25" Height="25"/>
                                <TextBlock Text="Personel" Margin="12,0,0,0" VerticalAlignment="Center" FontWeight="Bold" FontSize="18"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="BtnMusteri" Click="BtnMusteri_Click" Style="{StaticResource MaterialDesignRaisedButton}" Height="50" Width="185" materialDesign:ButtonAssist.CornerRadius="20" Margin="0,2" Background="SteelBlue" BorderBrush="Transparent">
                            <StackPanel Orientation="Horizontal" Width="140">
                                <materialDesign:PackIcon Kind="AccountPlus" Width="25" Height="25"/>
                                <TextBlock Text="Müşteri" Margin="12,0,0,0" VerticalAlignment="Center" FontWeight="Bold" FontSize="18"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="BtnStok" Click="BtnStok_Click" Style="{StaticResource MaterialDesignRaisedButton}" Height="50" Width="185" materialDesign:ButtonAssist.CornerRadius="20" Margin="0,2" Background="SteelBlue" BorderBrush="Transparent">
                            <StackPanel Orientation="Horizontal" Width="140">
                                <materialDesign:PackIcon Kind="Warehouse" Width="25" Height="25"/>
                                <TextBlock Text="Stok" Margin="12,0,0,0" VerticalAlignment="Center" FontWeight="Bold" FontSize="18"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="BtnKasa" Click="BtnKasa_Click" Style="{StaticResource MaterialDesignRaisedButton}" Height="50" Width="185" materialDesign:ButtonAssist.CornerRadius="20" Margin="0,2" Background="SteelBlue" BorderBrush="Transparent">
                            <StackPanel Orientation="Horizontal" Width="140">
                                <materialDesign:PackIcon Kind="CashRegister" Width="25" Height="25"/>
                                <TextBlock Text="Kasa" Margin="12,0,0,0" VerticalAlignment="Center" FontWeight="Bold" FontSize="18"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="BtnCekSenet" Click="BtnCekSenet_Click" Style="{StaticResource MaterialDesignRaisedButton}" Height="50" Width="185" materialDesign:ButtonAssist.CornerRadius="20" Margin="0,2" Background="SteelBlue" BorderBrush="Transparent">
                            <StackPanel Orientation="Horizontal" Width="140">
                                <materialDesign:PackIcon Kind="Checkbook" Width="25" Height="25"/>
                                <TextBlock Text="Çek/Senet" Margin="12,0,0,0" VerticalAlignment="Center" FontWeight="Bold" FontSize="18"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="BtnRandevu" Click="BtnRandevu_Click" Style="{StaticResource MaterialDesignRaisedButton}" Height="50" Width="185" materialDesign:ButtonAssist.CornerRadius="20" Margin="0,2" Background="SteelBlue" BorderBrush="Transparent">
                            <StackPanel Orientation="Horizontal" Width="140">
                                <materialDesign:PackIcon Kind="CalendarClock" Width="25" Height="25"/>
                                <TextBlock Text="Randevu" Margin="12,0,0,0" VerticalAlignment="Center" FontWeight="Bold" FontSize="18"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="BtnMuhasebe" Click="BtnMuhasebe_Click" Style="{StaticResource MaterialDesignRaisedButton}" Height="50" Width="185" materialDesign:ButtonAssist.CornerRadius="20" Margin="0,2" Background="SteelBlue" BorderBrush="Transparent">
                            <StackPanel Orientation="Horizontal" Width="140">
                                <materialDesign:PackIcon Kind="Finance" Width="25" Height="25"/>
                                <TextBlock Text="Muhasebe" Margin="12,0,0,0" VerticalAlignment="Center" FontWeight="Bold" FontSize="18"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="BtnUrunler" Click="BtnUrunler_Click" Style="{StaticResource MaterialDesignRaisedButton}" Height="50" Width="185" materialDesign:ButtonAssist.CornerRadius="20" Margin="0,2" Background="SteelBlue" BorderBrush="Transparent">
                            <StackPanel Orientation="Horizontal" Width="140">
                                <materialDesign:PackIcon Kind="PackageVariantClosed" Width="25" Height="25"/>
                                <TextBlock Text="Ürünler" Margin="12,0,0,0" VerticalAlignment="Center" FontWeight="Bold" FontSize="18"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="BtnFirmalar" Click="BtnFirmalar_Click" Style="{StaticResource MaterialDesignRaisedButton}" Height="50" Width="185" materialDesign:ButtonAssist.CornerRadius="20" Margin="0,2" Background="SteelBlue" BorderBrush="Transparent">
                            <StackPanel Orientation="Horizontal" Width="140">
                                <materialDesign:PackIcon Kind="OfficeBuilding" Width="25" Height="25"/>
                                <TextBlock Text="Firmalar" Margin="12,0,0,0" VerticalAlignment="Center" FontWeight="Bold" FontSize="18"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="BtnGrafikler" Click="BtnGrafikler_Click" Style="{StaticResource MaterialDesignRaisedButton}" Height="50" Width="185" materialDesign:ButtonAssist.CornerRadius="20" Margin="0,2" Background="SteelBlue" BorderBrush="Transparent">
                            <StackPanel Orientation="Horizontal" Width="140">
                                <materialDesign:PackIcon Kind="ChartBar" Width="25" Height="25"/>
                                <TextBlock Text="Grafikler" Margin="12,0,0,0" VerticalAlignment="Center" FontWeight="Bold" FontSize="18"/>
                            </StackPanel>
                        </Button>
                        <Separator Margin="15,8" Background="White" Opacity="0.4"/>
                        <Button Click="BtnAnaMenu_Click" Style="{StaticResource MaterialDesignRaisedButton}" Height="50" Width="185" materialDesign:ButtonAssist.CornerRadius="20" Margin="0,2" Background="IndianRed" BorderBrush="Transparent">
                            <StackPanel Orientation="Horizontal" Width="140">
                                <materialDesign:PackIcon Kind="ArrowBack" Width="25" Height="25"/>
                                <TextBlock Text="Ana Menü" Margin="12,0,0,0" VerticalAlignment="Center" FontWeight="Bold" FontSize="18"/>
                            </StackPanel>
                        </Button>
                        <Separator Margin="15,8" Background="White" Opacity="0.4"/>
                        <Button x:Name="btnAyarlar" Click="BtnAyarlar_Click" Style="{StaticResource MaterialDesignRaisedButton}" Height="50" Width="185" materialDesign:ButtonAssist.CornerRadius="20" Margin="0,2" Background="Gray" BorderBrush="Transparent">
                            <StackPanel Orientation="Horizontal" Width="140">
                                <materialDesign:PackIcon Kind="Settings" Width="25" Height="25" Foreground="#333"/>
                                <TextBlock Text="Ayarlar" Margin="12,0,0,0" VerticalAlignment="Center" FontWeight="Bold" FontSize="18" Foreground="#333"/>
                            </StackPanel>
                        </Button>
                        <Button Click="BtnKapat_Click" Style="{StaticResource MaterialDesignRaisedButton}" Height="50" Width="185" materialDesign:ButtonAssist.CornerRadius="20" Margin="0,2" Background="Crimson" BorderBrush="Transparent">
                            <StackPanel Orientation="Horizontal" Width="140">
                                <materialDesign:PackIcon Kind="Power" Width="25" Height="25"/>
                                <TextBlock Text="Kapat" Margin="12,0,0,0" VerticalAlignment="Center" FontWeight="Bold" FontSize="18"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <Border Grid.Column="1" Margin="10,12,12,12" CornerRadius="25" Background="#22FFFFFF" BorderBrush="#33FFFFFF" BorderThickness="1">
            <Grid>
                <Image Source="/Assets/aıdajk.png" Width="550" Height="550" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False" Opacity="0.6">
                    <Image.Effect>
                        <DropShadowEffect ShadowDepth="0" Color="Black" BlurRadius="20"/>
                    </Image.Effect>
                </Image>

                <ContentControl x:Name="SayfaIcerigi"/>


                <materialDesign:Badged x:Name="BadgeVade"   Badge="0"    BadgePlacementMode="TopLeft" VerticalAlignment="Top"   HorizontalAlignment="Right"  Margin="0,0,-11,0" Visibility="Collapsed">
                    <Button x:Name="BtnVadeBildirim"    Click="BtnVadeBildirim_Click" Style="{StaticResource MaterialDesignFloatingActionButton}" Width="40" Height="40" Background="OrangeRed" BorderBrush="Transparent">
                        <materialDesign:PackIcon Kind="Alarm" Width="28" Height="28" />
                    </Button>
                </materialDesign:Badged>



            </Grid>
        </Border>
    </Grid>
</Window>
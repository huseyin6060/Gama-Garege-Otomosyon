<UserControl x:Class="GamaGarage.Sayfalar.Randevu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
              xmlns:Veriler="clr-namespace:GamaGarage.Veriler"
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="1600">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Border CornerRadius="35" ClipToBounds="True" Margin="5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <UniformGrid Rows="1" Margin="20,10,20,0">
                    <StackPanel>
                        <TextBlock Text="LİFT" HorizontalAlignment="Center" FontWeight="Bold" Foreground="SteelBlue" FontSize="16"/>
                        <WrapPanel x:Name="wpLiftler" HorizontalAlignment="Center" Margin="5"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="ÇUKUR" HorizontalAlignment="Center" FontWeight="Bold" Foreground="SteelBlue" FontSize="16"/>
                        <WrapPanel x:Name="wpCukurlar" HorizontalAlignment="Center" Margin="5"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="GARAJ" HorizontalAlignment="Center" FontWeight="Bold" Foreground="SteelBlue" FontSize="16"/>
                        <WrapPanel x:Name="wpGarajlar" HorizontalAlignment="Center" Margin="5"/>
                    </StackPanel>
                </UniformGrid>

                <Grid Grid.Row="1" Margin="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="420"/>
                        <ColumnDefinition Width="250"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" Margin="0,0,15,0">
                        <materialDesign:Card materialDesign:ElevationAssist.Elevation="Dp3" UniformCornerRadius="25">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Background="LightGray" CornerRadius="25,25,0,0" Padding="10">
                                    <UniformGrid Columns="4">
                                        <TextBox x:Name="txtRandevuAra" TextChanged="txtRandevuAra_TextChanged" materialDesign:HintAssist.Hint="Ad veya Plaka ile Ara..." Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="20" Background="LightGray" Margin="5,0"/>
                                        <DatePicker x:Name="dpBaslangicGenel" Margin="5,0" materialDesign:HintAssist.Hint="Başlangıç"/>
                                        <DatePicker x:Name="dpBitisGenel" Margin="5,0" materialDesign:HintAssist.Hint="Bitiş"/>
                                        <Button x:Name="btnFiltreleGenel" Click="btnFiltreleGenel_Click" Content="Filtrele" Background="SteelBlue" materialDesign:ButtonAssist.CornerRadius="18" Height="45"/>
                                    </UniformGrid>
                                </Border>

                                <DataGrid x:Name="dgRandevuListesi" Grid.Row="1" MinHeight="400" Background="White" BorderThickness="0" Margin="5" AutoGenerateColumns="True" IsReadOnly="True" SelectionMode="Single" SelectionUnit="FullRow" AutoGeneratedColumns="dgRandevuListesi_AutoGeneratedColumns" SelectionChanged="dgRandevuListesi_SelectionChanged"/>
                            </Grid>
                        </materialDesign:Card>
                    </Grid>

                    <StackPanel Grid.Column="1" Margin="5,0">
                        <materialDesign:Card Background="#F8FFFFFF" UniformCornerRadius="25" Padding="0" Margin="0,0,0,10">
                            <StackPanel>
                                <Border Background="#E0E0E0" CornerRadius="25,25,0,0" Height="70">
                                    <TextBlock Text="ARABA DETAYLARI" FontWeight="Black" Foreground="SteelBlue" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="20"/>
                                </Border>
                                <StackPanel Margin="20,15">
                                    <UniformGrid Columns="2">
                                        <TextBox x:Name="txtRAd" Veriler:InputKisitlayici.SadeceMetin="True" materialDesign:HintAssist.Hint="Ad" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="15" Margin="3" />
                                        <TextBox x:Name="txtRSoyad" Veriler:InputKisitlayici.SadeceMetin="True" materialDesign:HintAssist.Hint="Soyad" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="15" Margin="3"/>
                                    </UniformGrid>
                                    <UniformGrid Columns="2">
                                        <DatePicker x:Name="dpRandevuBaslangıc" Margin="5,0" materialDesign:HintAssist.Hint="Başlangıç"/>
                                        <DatePicker x:Name="dpRandevuBitis" Margin="5,0" materialDesign:HintAssist.Hint="Bitiş"/>
                                    </UniformGrid>
                                    <TextBox x:Name="Rplaka" MaxLength="12" materialDesign:HintAssist.Hint="Araç Plaka" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="15" Margin="3"/>
                                    <TextBox x:Name="txtRTelefon" Veriler:InputKisitlayici.SadeceSayi="True" MaxLength="11" materialDesign:HintAssist.Hint="Telefon (05xx...)" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="15" Margin="3" />
                                    <TextBox x:Name="txtRTutar" Veriler:InputKisitlayici.SadeceSayi="True" materialDesign:HintAssist.Hint="Toplam Tutar" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="12" Margin="3" />


                                    <TextBox x:Name="txtRAciklama" materialDesign:HintAssist.Hint="Yapılan İşlem Açıklaması" Height="80" TextWrapping="Wrap" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="15" Margin="3" AcceptsReturn="True"/>



                                    <ComboBox x:Name="cmbRPersonel" materialDesign:HintAssist.Hint="Personel Seç" Style="{StaticResource MaterialDesignOutlinedComboBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="15" Margin="0,5"/>
                                </StackPanel>
                            </StackPanel>
                        </materialDesign:Card>

                        <materialDesign:Card Background="#F8FFFFFF" UniformCornerRadius="25" Padding="0">
                            <StackPanel>
                                <Border Background="#E0E0E0" CornerRadius="25,25,0,0" Height="70">
                                    <TextBlock Text="İŞLEM KAYDI" FontWeight="Black" Foreground="SteelBlue" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="20"/>
                                </Border>
                                <StackPanel x:Name="spIslemKayitlari" Margin="20" MinHeight="100">
                                </StackPanel>
                            </StackPanel>
                        </materialDesign:Card>
                    </StackPanel>

                    <StackPanel Grid.Column="2" VerticalAlignment="Top" Margin="15,0">
                        <Button x:Name="btnLift" Click="btnLift_Click" Height="60" materialDesign:ButtonAssist.CornerRadius="30" Background="ForestGreen" Margin="0,10">
                            <StackPanel Orientation="Horizontal" Width="180">
                                <materialDesign:PackIcon Kind="Forklift" Width="26" Height="26" VerticalAlignment="Center"/>
                                <TextBlock Text="Lift Ekle" Margin="15,0,0,0" VerticalAlignment="Center" FontWeight="Bold"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="btnCukur" Click="btnCukur_Click" Height="60" materialDesign:ButtonAssist.CornerRadius="30" Background="ForestGreen" Margin="0,10">
                            <StackPanel Orientation="Horizontal" Width="180">
                                <materialDesign:PackIcon Kind="Plus" Width="26" Height="26" VerticalAlignment="Center"/>
                                <TextBlock Text="Çukur Ekle" Margin="15,0,0,0" VerticalAlignment="Center" FontWeight="Bold"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="btnGaraj" Click="btnGaraj_Click" Height="60" materialDesign:ButtonAssist.CornerRadius="30" Background="ForestGreen" Margin="0,10">
                            <StackPanel Orientation="Horizontal" Width="180">
                                <materialDesign:PackIcon Kind="Garage" Width="26" Height="26" VerticalAlignment="Center"/>
                                <TextBlock Text="Garaj Ekle" Margin="15,0,0,0" VerticalAlignment="Center" FontWeight="Bold"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="btnGCLSil" Click="btnGCLSil_Click" Height="60" materialDesign:ButtonAssist.CornerRadius="30" Background="Red" Margin="0,10">
                            <StackPanel Orientation="Horizontal" Width="180">
                                <materialDesign:PackIcon Kind="Delete" Width="26" Height="26" VerticalAlignment="Center"/>
                                <TextBlock Text="Garaj Lift Çukur Sil" Margin="15,0,0,0" VerticalAlignment="Center" FontWeight="Bold"/>
                            </StackPanel>
                        </Button>

                        <Separator Margin="15,20" Background="White" Opacity="0.6"/>

                        <Button x:Name="btnRandevuEkle" Click="btnRandevuEkle_Click" Height="60" materialDesign:ButtonAssist.CornerRadius="30" Background="ForestGreen" Margin="0,10">
                            <StackPanel Orientation="Horizontal" Width="180">
                                <materialDesign:PackIcon Kind="Plus" Width="26" Height="26" VerticalAlignment="Center"/>
                                <TextBlock Text="Randevu Ekle" Margin="15,0,0,0" VerticalAlignment="Center" FontWeight="Bold"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="btnRandevuGuncelle" Click="btnRandevuGuncelle_Click" Height="60" materialDesign:ButtonAssist.CornerRadius="30" Background="SteelBlue" Margin="0,10">
                            <StackPanel Orientation="Horizontal" Width="180">
                                <materialDesign:PackIcon Kind="Refresh" Width="26" Height="26" VerticalAlignment="Center"/>
                                <TextBlock Text="Randevu Güncelle" Margin="15,0,0,0" VerticalAlignment="Center" FontWeight="Bold"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="btnRandevuSil" Click="btnRandevuSil_Click" Height="60" materialDesign:ButtonAssist.CornerRadius="30" Background="Red" Margin="0,10">
                            <StackPanel Orientation="Horizontal" Width="180">
                                <materialDesign:PackIcon Kind="Delete" Width="26" Height="26" VerticalAlignment="Center"/>
                                <TextBlock Text="Randevu Sil" Margin="15,0,0,0" VerticalAlignment="Center" FontWeight="Bold"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="btnYenile" Click="btnYenile_Click" Height="65" materialDesign:ButtonAssist.CornerRadius="32" Style="{StaticResource MaterialDesignRaisedDarkButton}" Margin="0,8" Background="#455A64" BorderBrush="Transparent">
                            <StackPanel Orientation="Horizontal" Width="190">
                                <materialDesign:PackIcon Kind="Refresh" Width="26" Height="26" VerticalAlignment="Center"/>
                                <TextBlock Text="Ekranı Yenile" Margin="15,0,0,0" VerticalAlignment="Center" FontWeight="Bold" FontSize="14"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="btnRTemizle" Click="btnRTemizle_Click" Height="60" materialDesign:ButtonAssist.CornerRadius="30" Background="Purple" Margin="0,10">
                            <StackPanel Orientation="Horizontal" Width="180">
                                <materialDesign:PackIcon Kind="DeleteSweep" Width="26" Height="26" VerticalAlignment="Center"/>
                                <TextBlock Text="Temizle" Margin="15,0,0,0" VerticalAlignment="Center" FontWeight="Bold"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </ScrollViewer>
</UserControl>
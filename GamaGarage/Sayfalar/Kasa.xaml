<UserControl x:Class="GamaGarage.Sayfalar.Kasa"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:Veriler="clr-namespace:GamaGarage.Veriler"
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="1600">

    <Border CornerRadius="35" ClipToBounds="True" Margin="5" >
        <Grid>
        

            <Grid Margin="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="450"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="0,0,15,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <materialDesign:Card Grid.Row="0" Margin="0,0,0,10" UniformCornerRadius="25">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="LightGray" CornerRadius="25,25,0,0" Padding="10">
                                <UniformGrid Columns="4">
                                    <TextBox   x:Name="txtKasaAra1"  materialDesign:HintAssist.Hint="Ara..."  TextChanged="txtKasaAra_TextChanged1"    Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="20" Background="LightGray" Margin="3"/>
                                    
                                    
                                   
                                    <DatePicker x:Name="dpKDuzenleme1" Grid.Column="1"  Margin="5,0" Background="#ADD8E6" materialDesign:TextFieldAssist.TextFieldCornerRadius="15" materialDesign:HintAssist.Hint="Başlangıç"/>
                                    <DatePicker x:Name="dpKBDuzenleme1" Grid.Column="1"  Margin="5,0" Background="#ADD8E6" materialDesign:TextFieldAssist.TextFieldCornerRadius="15" materialDesign:HintAssist.Hint="Bitiş"/>



                                    <Button Content="Filtrele" Click="btnFiltrele_Click1" Style="{StaticResource MaterialDesignRaisedButton}" materialDesign:ButtonAssist.CornerRadius="20" Background="SteelBlue" Height="50" Margin="3" Foreground="LightGray"/>
                                </UniformGrid>
                            </Border>



                            <DataGrid x:Name="dgKasaGelirListesi"  Grid.Row="1"   Background="White"  BorderThickness="0"  Margin="5" AutoGenerateColumns="True"  IsReadOnly="True"   SelectionMode="Single" SelectionChanged="dgKasaGelirListesi_SelectionChanged" SelectionUnit="FullRow" AutoGeneratedColumns="dgKasaGelirListesi_AutoGeneratedColumns"/>

                        </Grid>
                    </materialDesign:Card>

                    <materialDesign:Card Grid.Row="1" Margin="0,10,0,0" UniformCornerRadius="25">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="LightGray" CornerRadius="25,25,0,0" Padding="10">
                                <UniformGrid Columns="4">
                                    <TextBox x:Name="txtKasaAra2" materialDesign:HintAssist.Hint="Ara..." TextChanged="txtKasaAra_TextChanged2"  Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="20" Background="LightGray" Margin="3"/>

                                    <DatePicker x:Name="dpKDuzenleme2" Grid.Column="1"  Margin="5,0" Background="#ADD8E6" materialDesign:TextFieldAssist.TextFieldCornerRadius="15" materialDesign:HintAssist.Hint="Başlangıç"/>
                                    <DatePicker x:Name="dpKBDuzenleme2" Grid.Column="1"  Margin="5,0" Background="#ADD8E6" materialDesign:TextFieldAssist.TextFieldCornerRadius="15" materialDesign:HintAssist.Hint="Bitiş"/>


                                    <Button Content="Filtrele" Click="btnFiltrele_Click2" Style="{StaticResource MaterialDesignRaisedButton}" materialDesign:ButtonAssist.CornerRadius="20" Background="SteelBlue" Height="50" Margin="3" Foreground="LightGray"/>
                                </UniformGrid>
                            </Border>


                            <DataGrid x:Name="dgKasaGiderListesi"  Grid.Row="1"   Background="White"  BorderThickness="0"  Margin="5" AutoGenerateColumns="True"  IsReadOnly="True"   SelectionMode="Single" SelectionChanged="dgKasaGiderListesi_SelectionChanged" SelectionUnit="FullRow" AutoGeneratedColumns="dgKasaGiderListesi_AutoGeneratedColumns"/>

                        </Grid>
                    </materialDesign:Card>
                </Grid>

                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <materialDesign:Card Grid.Row="0" Background="White" UniformCornerRadius="25" Margin="0,0,0,10" Padding="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Background="LightGray" CornerRadius="25,25,0,0" Height="75">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <materialDesign:PackIcon Kind="AccountCash" Width="50" Height="50" Foreground="SteelBlue"/>
                                    <TextBlock Text="GELİR İŞLEMLERİ" Foreground="SteelBlue" FontWeight="Black" FontSize="20" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="20,10">

                                <TextBox x:Name="txtToplamGelir" materialDesign:HintAssist.Hint="Toplam Gelir" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="15" Margin="5" Focusable="False" IsReadOnly="True" IsHitTestVisible="False"/>


                                <UniformGrid Columns="2">
                                    <TextBox x:Name="txtTutar" Veriler:InputKisitlayici.SadeceSayi="True" materialDesign:HintAssist.Hint="Tutar" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="15" Margin="5" />
                                    <DatePicker x:Name="dpKOdemeTarih" Grid.Column="1"  Margin="5,0" Background="#ADD8E6" materialDesign:TextFieldAssist.TextFieldCornerRadius="15" materialDesign:HintAssist.Hint="Tarih"/>

                                </UniformGrid>
                                <TextBox x:Name="txtKAciklama" materialDesign:HintAssist.Hint="Açıklama" Height="80" TextWrapping="Wrap" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="15" Margin="5" AcceptsReturn="True"/>

                                <UniformGrid Columns="2" Margin="0,10">
                                    <Button x:Name="btnGelirGirisi" Click="btnGelirGirisi_Click" Style="{StaticResource MaterialDesignRaisedButton}" Background="GreenYellow" Height="55" Margin="5" materialDesign:ButtonAssist.CornerRadius="27">
                                        <TextBlock Text="Gelir Giriş" FontSize="16" FontWeight="Bold"/>
                                    </Button>
                                    <Button x:Name="btnGelirSil" Click="btnGelirSil_Click" Style="{StaticResource MaterialDesignRaisedButton}" Background="IndianRed" Height="55" Margin="5" materialDesign:ButtonAssist.CornerRadius="27">
                                        <TextBlock Text="Gelir Sil" FontSize="16" FontWeight="Bold"/>
                                    </Button>
                                </UniformGrid>
                            </StackPanel>
                        </Grid>
                    </materialDesign:Card>

                    <materialDesign:Card Grid.Row="1" Background="White" UniformCornerRadius="25" Margin="0,10,0,0" Padding="0" VerticalAlignment="Top" Height="415">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Background="LightGray" CornerRadius="25,25,0,0" Height="60">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <materialDesign:PackIcon Kind="CashMinus" Width="35" Height="35" Foreground="SteelBlue"/>
                                    <TextBlock Text="GİDER İŞLEMLERİ" Foreground="SteelBlue" FontWeight="Black" FontSize="18" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <StackPanel Grid.Row="1" VerticalAlignment="Top" Margin="15,0">
                                <TextBox x:Name="txtToplamGider" materialDesign:HintAssist.Hint="Toplam Gider" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="15" Margin="0,15,0,-13" Focusable="False" IsReadOnly="True" IsHitTestVisible="False"/>

                                <UniformGrid Columns="2" Margin="0,15,0,-15">
                                    <TextBox x:Name="txtGiderTutar" Veriler:InputKisitlayici.SadeceSayi="True" materialDesign:HintAssist.Hint="Tutar" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="15" Margin="3" />
                                    <DatePicker x:Name="dpGiderOdemeTarih" Margin="3" Background="#ADD8E6" materialDesign:TextFieldAssist.TextFieldCornerRadius="15" materialDesign:HintAssist.Hint="Tarih" VerticalAlignment="Center"/>
                                </UniformGrid>

                                <TextBox x:Name="txtAciklama" materialDesign:HintAssist.Hint="Açıklama" Height="60" TextWrapping="Wrap" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="15" Margin="0,20,0,-13" AcceptsReturn="True"/>
                                <UniformGrid Columns="2" Margin="0,15,0,0">
                                    <Button x:Name="btnGiderGirisi" Click="btnGiderGirisi_Click" Style="{StaticResource MaterialDesignRaisedButton}" Background="GreenYellow" Height="55" Margin="3" materialDesign:ButtonAssist.CornerRadius="25">
                                        <TextBlock Text="Gider Giriş" FontSize="14" FontWeight="Bold" Foreground="Black"/>
                                    </Button>
                                    <Button x:Name="btnGiderSil" Click="btnGiderSil_Click" Style="{StaticResource MaterialDesignRaisedButton}" Background="IndianRed" Height="55" Margin="3" materialDesign:ButtonAssist.CornerRadius="25">
                                        <TextBlock Text="Gider Sil" FontSize="14" FontWeight="Bold" Foreground="White"/>
                                    </Button>
                                </UniformGrid>

                                <Button x:Name="btnYenile" Click="btnYenile_Click" Height="60" Width="300" materialDesign:ButtonAssist.CornerRadius="25" Style="{StaticResource MaterialDesignRaisedDarkButton}" Margin="0,2,0,0" Background="#455A64" BorderBrush="Transparent">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Refresh" Width="22" Height="22" VerticalAlignment="Center"/>
                                        <TextBlock Text="Ekranı Yenile" Margin="10,0,0,0" VerticalAlignment="Center" FontWeight="Bold" FontSize="13"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </materialDesign:Card>

                </Grid>
                
            </Grid>
            
        </Grid>
        
    </Border>
</UserControl>
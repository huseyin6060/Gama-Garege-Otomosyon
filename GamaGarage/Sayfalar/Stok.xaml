<UserControl x:Class="GamaGarage.Sayfalar.Stok"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:Veriler="clr-namespace:GamaGarage.Veriler"
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="1600">

    <Grid >
     

        <Grid Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition Width="230"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,0,15,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <materialDesign:Card Grid.Row="0" Margin="0,0,0,12" materialDesign:ElevationAssist.Elevation="Dp3" UniformCornerRadius="25">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="LightGray" CornerRadius="25,25,0,0" Padding="10">
                            <UniformGrid Columns="4">
                                <TextBox x:Name="txtUrunAra1" TextChanged="txtUrunAra1_TextChanged" materialDesign:HintAssist.Hint="Ürün Ara..." Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="20" Background="LightGray" Margin="5,0"/>
                                <DatePicker x:Name="dpBaslangicFiltre1" Grid.Column="1" Margin="5,0" Background="#ADD8E6" materialDesign:TextFieldAssist.TextFieldCornerRadius="15" materialDesign:HintAssist.Hint="Başlangıç"/>

                                <DatePicker x:Name="dpBitisFiltre1" Grid.Column="1" Margin="5,0" Background="#ADD8E6" materialDesign:TextFieldAssist.TextFieldCornerRadius="15" materialDesign:HintAssist.Hint="Bitiş"/>

                                <Button x:Name="btnUrunFiltrele1" Click="btnUrunFiltrele1_Click" Content="Filtrele" Style="{StaticResource MaterialDesignRaisedButton}" materialDesign:ButtonAssist.CornerRadius="18" Margin="5,0" Background="SteelBlue" Height="45" Foreground="LightGray"/>
                            </UniformGrid>
                        </Border>
                        <DataGrid x:Name="dgUrunleriListesi" Grid.Row="1" Background="White" BorderThickness="0" Margin="5" AutoGenerateColumns="True"  IsReadOnly="True"   SelectionMode="Single" SelectionChanged="dgUrunleriListesi_SelectionChanged"  SelectionUnit="FullRow" AutoGeneratedColumns="dgUrunleriListesi_AutoGeneratedColumns"/>
                       
                    </Grid>
                </materialDesign:Card>

                <materialDesign:Card Grid.Row="1" materialDesign:ElevationAssist.Elevation="Dp3" UniformCornerRadius="25">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="LightGray" CornerRadius="25,25,0,0" Padding="10">
                            <UniformGrid Columns="4">
                                <TextBox x:Name="txtSatısAra2" materialDesign:HintAssist.Hint="Satış Ara..." Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="20" Background="LightGray" Margin="5,0"/>
                                <DatePicker x:Name="dpBaslangicFiltre2" Grid.Column="1" Margin="5,0" Background="#ADD8E6" materialDesign:TextFieldAssist.TextFieldCornerRadius="15" materialDesign:HintAssist.Hint="Başlangıç"/>

                                <DatePicker x:Name="dpBitisFiltre2" Grid.Column="1" Margin="5,0" Background="#ADD8E6" materialDesign:TextFieldAssist.TextFieldCornerRadius="15" materialDesign:HintAssist.Hint="Bitiş"/>
                                <Button x:Name="btnSatısFiltrele" Click="btnUrunFiltrele1_Click" Content="Filtrele" Style="{StaticResource MaterialDesignRaisedButton}" materialDesign:ButtonAssist.CornerRadius="18" Margin="5,0" Background="SteelBlue" Height="45" Foreground=" LightGray"/>
                            </UniformGrid>
                        </Border>

                        <DataGrid x:Name="dgSatısTablo" Grid.Row="1" Background="White" BorderThickness="0" Margin="5" AutoGenerateColumns="True"  IsReadOnly="True"   SelectionMode="Single" SelectionChanged="dgSatısTablo_SelectionChanged" SelectionUnit="FullRow" AutoGeneratedColumns="dgSatısTablo_AutoGeneratedColumns"/>

                    </Grid>
                </materialDesign:Card>
            </Grid>

            <materialDesign:Card Grid.Column="1" Background="#F8FFFFFF" UniformCornerRadius="30" Margin="5,0" materialDesign:ElevationAssist.Elevation="Dp6" VerticalAlignment="Stretch">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="LightGray" CornerRadius="30,30,0,0" Height="69">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="PackageVariant" Width="50" Height="50" Foreground="SteelBlue" VerticalAlignment="Center"/>
                            <TextBlock Text="STOK KAYIT VE DETAY" Foreground="SteelBlue" FontWeight="Black" FontSize="20" Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="20">
                            <TextBox x:Name="txtUrunAd" IsReadOnly="True" materialDesign:HintAssist.Hint="Ürün Adı" materialDesign:TextFieldAssist.HasClearButton="True" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="15" Margin="0,10"  Focusable="False" IsHitTestVisible="False"/>
                            <TextBox x:Name="txtBirimfiyat" Veriler:InputKisitlayici.SadeceSayi="True" materialDesign:HintAssist.Hint="Birim Fiyatı"  materialDesign:TextFieldAssist.HasClearButton="True" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="15" Margin="0,10" />
                            <TextBox x:Name="txtAdet" Veriler:InputKisitlayici.SadeceSayi="True" materialDesign:HintAssist.Hint="Adet"  materialDesign:TextFieldAssist.HasClearButton="True" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="15" Margin="0,10"/>

                         
                       
                            <DatePicker x:Name="dpUrunCikis" Grid.Column="1" Margin="1,0" Background="#ADD8E6" materialDesign:TextFieldAssist.TextFieldCornerRadius="15" materialDesign:HintAssist.Hint="İşlem Tarihi" Height="55"/>

                           

                            <TextBox x:Name="txtSAciklama" materialDesign:HintAssist.Hint="Açıklama ve Notlar" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="15" Margin="0,20" Height="300" TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Top" VerticalScrollBarVisibility="Auto"/>

                        </StackPanel>
                    </ScrollViewer>

                   
                </Grid>
            </materialDesign:Card>

            <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="15,0">
                <Button x:Name="btnStokEkle" Click="btnStokEkle_Click" Height="60" materialDesign:ButtonAssist.CornerRadius="30" Style="{StaticResource MaterialDesignRaisedDarkButton}" Margin="0,8" Background="#333">
                    <StackPanel Orientation="Horizontal" Width="170">
                        <materialDesign:PackIcon Kind="Money" Width="26" Height="26" VerticalAlignment="Center"/>
                        <TextBlock Text="Stok Sat" Margin="15,0,0,0" VerticalAlignment="Center" FontWeight="Bold" FontSize="14"/>
                    </StackPanel>
                </Button>
                
                <Button x:Name="btnStokSil" Click="btnStokSil_Click" Height="60" materialDesign:ButtonAssist.CornerRadius="30" Style="{StaticResource MaterialDesignRaisedDarkButton}" Margin="0,8" Background="#C62828">
                    <StackPanel Orientation="Horizontal" Width="170">
                        <materialDesign:PackIcon Kind="Delete" Width="26" Height="26" VerticalAlignment="Center"/>
                        <TextBlock Text="Stok Sil" Margin="15,0,0,0" VerticalAlignment="Center" FontWeight="Bold" FontSize="14"/>
                    </StackPanel>
                </Button>
                <Button x:Name="btnStokGuncelle" Click="btnStokGuncelle_Click" Height="60" materialDesign:ButtonAssist.CornerRadius="30" Style="{StaticResource MaterialDesignRaisedDarkButton}" Margin="0,8" Background="#1565C0">
                    <StackPanel Orientation="Horizontal" Width="170">
                        <materialDesign:PackIcon Kind="Update" Width="26" Height="26" VerticalAlignment="Center"/>
                        <TextBlock Text="Güncelle" Margin="15,0,0,0" VerticalAlignment="Center" FontWeight="Bold" FontSize="14"/>
                    </StackPanel>
                </Button>
                <Button x:Name="btnStokGerial" Click="btnStokGerial_Click" Height="60" materialDesign:ButtonAssist.CornerRadius="30" Style="{StaticResource MaterialDesignRaisedDarkButton}" Margin="0,8" Background="Orange">
                    <StackPanel Orientation="Horizontal" Width="170">
                        <materialDesign:PackIcon Kind="Undo" Width="26" Height="26" VerticalAlignment="Center"/>
                        <TextBlock Text="Geri Al" Margin="15,0,0,0" VerticalAlignment="Center" FontWeight="Bold" FontSize="14"/>
                    </StackPanel>
                </Button>
                <Button x:Name="btnYenile" Click="btnYenile_Click" Height="65" materialDesign:ButtonAssist.CornerRadius="32" Style="{StaticResource MaterialDesignRaisedDarkButton}" Margin="0,8" Background="#455A64" BorderBrush="Transparent">
                    <StackPanel Orientation="Horizontal" Width="190">
                        <materialDesign:PackIcon Kind="Refresh" Width="26" Height="26" VerticalAlignment="Center"/>
                        <TextBlock Text="Ekranı Yenile" Margin="15,0,0,0" VerticalAlignment="Center" FontWeight="Bold" FontSize="14"/>
                    </StackPanel>
                </Button>

                <Separator Margin="25,20" Background="White" Opacity="0.6"/>

                <Button x:Name="btnSTemizle" Click="btnSTemizle_Click" Height="60" materialDesign:ButtonAssist.CornerRadius="30" Style="{StaticResource MaterialDesignRaisedDarkButton}" Margin="0,8" Background="#555">
                    <StackPanel Orientation="Horizontal" Width="170">
                        <materialDesign:PackIcon Kind="DeleteSweep" Width="26" Height="26" VerticalAlignment="Center"/>
                        <TextBlock Text="Temizle" Margin="15,0,0,0" VerticalAlignment="Center" FontWeight="Bold" FontSize="14"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
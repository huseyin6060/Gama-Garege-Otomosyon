<UserControl x:Class="GamaGarage.Sayfalar.Firmalar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:Veriler="clr-namespace:GamaGarage.Veriler"
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="1600">

    <Border CornerRadius="35" ClipToBounds="True" Margin="5">
        <ContentControl x:Name="SayfaIcerikKonteynir">
            <Grid x:Name="AnaGrid" Margin="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="420"/>
                    <ColumnDefinition Width="230"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="0,0,15,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <materialDesign:Card Grid.Row="0" Margin="0,0,0,12" materialDesign:ElevationAssist.Elevation="Dp3" UniformCornerRadius="25">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="LightGray" CornerRadius="25,25,0,0" Padding="10">
                                <UniformGrid Columns="4">
                                    <TextBox x:Name="txtFirmaAra1" TextChanged="txtFirmaAra1_TextChanged" materialDesign:HintAssist.Hint="Ad veya Plaka ile Ara..." Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="20" Background="LightGray" Margin="5,0"/>
                                    <DatePicker x:Name="dpFBaslangicFiltre1" Margin="5,0" Background="#ADD8E6" materialDesign:TextFieldAssist.TextFieldCornerRadius="15" materialDesign:HintAssist.Hint="Başlangıç"/>
                                    <DatePicker x:Name="dpFBitisFiltre1" Margin="5,0" Background="#ADD8E6" materialDesign:TextFieldAssist.TextFieldCornerRadius="15" materialDesign:HintAssist.Hint="Bitiş"/>
                                    <Button x:Name="btnFFiltrele1" Click="btnFFiltrele1_Click" Content="Filtrele" Style="{StaticResource MaterialDesignRaisedButton}" materialDesign:ButtonAssist.CornerRadius="18" Margin="5,0" Background="SteelBlue" Height="45" Foreground="LightGray" />
                                </UniformGrid>
                            </Border>
                            <DataGrid x:Name="dgFirmaListesi" Grid.Row="1" Background="White" BorderThickness="0" Margin="5" AutoGenerateColumns="True" IsReadOnly="True" SelectionMode="Single" SelectionChanged="dgFirmaListesi_SelectionChanged" SelectionUnit="FullRow" AutoGeneratedColumns="dgFirmaListesi_AutoGeneratedColumns"/>
                        </Grid>
                    </materialDesign:Card>

                    <materialDesign:Card Grid.Row="1" materialDesign:ElevationAssist.Elevation="Dp3" UniformCornerRadius="25">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="LightGray" CornerRadius="25,25,0,0" Padding="10">
                                <UniformGrid Columns="4">
                                    <TextBox x:Name="txtFirmaAra2" TextChanged="txtFirmaAra2_TextChanged" materialDesign:HintAssist.Hint="Ödeme Ara..." Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="20" Background="LightGray" Margin="5,0"/>
                                    <DatePicker x:Name="dpFBaslangicFiltre2" Margin="5,0" Background="#ADD8E6" materialDesign:TextFieldAssist.TextFieldCornerRadius="15" materialDesign:HintAssist.Hint="Başlangıç"/>
                                    <DatePicker x:Name="dpFBitisFiltre2" Margin="5,0" Background="#ADD8E6" materialDesign:TextFieldAssist.TextFieldCornerRadius="15" materialDesign:HintAssist.Hint="Bitiş"/>
                                    <Button x:Name="btnFFiltrele2" Click="btnFFiltrele2_Click" Content="Filtrele" Style="{StaticResource MaterialDesignRaisedButton}" materialDesign:ButtonAssist.CornerRadius="18" Margin="5,0" Background="SteelBlue" Height="45" Foreground="LightGray" />
                                </UniformGrid>
                            </Border>
                            <DataGrid x:Name="dgFirmaAltTablo" Grid.Row="1" Background="White" BorderThickness="0" Margin="5" AutoGenerateColumns="True" IsReadOnly="True" SelectionMode="Single" SelectionChanged="dgFirmaAltTablo_SelectionChanged" SelectionUnit="FullRow" AutoGeneratedColumns="dgFirmaAltTablo_AutoGeneratedColumns"/>
                        </Grid>
                    </materialDesign:Card>
                </Grid>

                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="5,0">
                        <materialDesign:Card Background="#F8FFFFFF" UniformCornerRadius="25" Margin="0,0,0,10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="#E0E0E0" CornerRadius="25,25,0,0" Height="70">
                                    <TextBlock Text="FİRMA DETAYLARI" FontWeight="Black" Foreground="SteelBlue" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20"/>
                                </Border>
                                <StackPanel Grid.Row="1" Margin="20,15">
                                    <TextBox x:Name="txtFAd" Veriler:InputKisitlayici.SadeceMetin="True" materialDesign:HintAssist.Hint="Firma Ad" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="15" Margin="3"/>
                                    <TextBox x:Name="txtFYetkilisiAd" Veriler:InputKisitlayici.SadeceMetin="True" materialDesign:HintAssist.Hint="Firma Yetkilisi Adı" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="15" Margin="3"/>
                                    <TextBox x:Name="Telefon" Veriler:InputKisitlayici.SadeceSayi="True" MaxLength="11" materialDesign:HintAssist.Hint="Telefon(11 Hane)" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="15" Margin="3"/>
                                    <UniformGrid Columns="2" Height="55" Margin="3">
                                        <TextBox x:Name="txtFAdres" materialDesign:HintAssist.Hint="Adres" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="15" Margin="3"/>
                                        <TextBox x:Name="txtFGmail" materialDesign:HintAssist.Hint="Gmail" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="15" Margin="3"/>
                                    </UniformGrid>
                                    <DatePicker x:Name="dpFirmaTarihi" Margin="5,0" Background="#ADD8E6" materialDesign:TextFieldAssist.TextFieldCornerRadius="15" materialDesign:HintAssist.Hint="Firma Kayıt Tarihi" Height="55"/>
                                    <TextBox x:Name="txtFAciklama" materialDesign:HintAssist.Hint="Açıklama" Height="80" TextWrapping="Wrap" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="15" Margin="3" AcceptsReturn="True"/>
                                </StackPanel>
                            </Grid>
                        </materialDesign:Card>

                        <materialDesign:Card Background="#F8FFFFFF" UniformCornerRadius="25">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="#E0E0E0" CornerRadius="25,25,0,0" Height="70">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <materialDesign:PackIcon Kind="CashMultiple" Width="50" Height="50" Foreground="DarkGreen" VerticalAlignment="Center"/>
                                        <TextBlock Text="ÖDEME DETAYLARI" FontWeight="Black" Foreground="SteelBlue" Margin="8,0,0,0" VerticalAlignment="Center" FontSize="20"/>
                                    </StackPanel>
                                </Border>
                                <StackPanel Grid.Row="1" Margin="20,15">
                                    <UniformGrid Columns="2">
                                        <TextBox x:Name="txtFOAD" materialDesign:HintAssist.Hint="Firma Adı" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="12" Margin="2" Focusable="False" IsReadOnly="True" IsHitTestVisible="False"  />
                                        <TextBox x:Name="txtFOYetkilisi" materialDesign:HintAssist.Hint="Yetkilisi Adı" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="12" Margin="2" Focusable="False" IsReadOnly="True" IsHitTestVisible="False"/>
                                        <TextBox x:Name="txtFBorc" Veriler:InputKisitlayici.SadeceSayi="True" materialDesign:HintAssist.Hint="Toplam Borç" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="12" Margin="3" />
                                        <TextBox x:Name="txtFÖdenen" Veriler:InputKisitlayici.SadeceSayi="True" materialDesign:HintAssist.Hint="Ödenen" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="12" Margin="3" />
                                        
                                        <TextBox x:Name="txtFKalan" materialDesign:HintAssist.Hint="Kalan" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="12" Margin="3" IsReadOnly="True" Background="#F0F0F0" Focusable="False"  IsHitTestVisible="False"/>
                                        <TextBox x:Name="txtFSerino" MaxLength="6" Veriler:InputKisitlayici.SadeceSayi="True" materialDesign:HintAssist.Hint="Seri No" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="12" Margin="3" />

                                        <DatePicker x:Name="dpFOdemeTarih" Margin="5,0" Background="#ADD8E6" materialDesign:TextFieldAssist.TextFieldCornerRadius="15" materialDesign:HintAssist.Hint="İşlem Tarihi"/>
                                       <DatePicker x:Name="dpFVadeTarih" Margin="5,0" Background="#ADD8E6" materialDesign:TextFieldAssist.TextFieldCornerRadius="15" materialDesign:HintAssist.Hint="Vade Tarihi"/>
                                    </UniformGrid>
                                   
                                    <ComboBox x:Name="cmbFTuru" materialDesign:HintAssist.Hint="Evrak Türü" Style="{StaticResource MaterialDesignOutlinedComboBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="15" Margin="0,5">
                                        <ComboBoxItem Content="Çek"/>
                                        <ComboBoxItem Content="Senet"/>
                                    </ComboBox>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8">
                                        <RadioButton x:Name="rbÖdendi" Content="Ödendi" IsChecked="True" GroupName="PersonelDurum" Foreground="Green" Margin="0,0,150,0"/>
                                        <RadioButton x:Name="rbÖdenmedi" Content="Ödenmedi" GroupName="PersonelDurum" Foreground="Red"/>
                                    </StackPanel>
                                    <TextBox x:Name="txtFOdemeAciklama" materialDesign:HintAssist.Hint="Açıklama" Height="80" TextWrapping="Wrap" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="15" Margin="3" AcceptsReturn="True"/>
                                    <UniformGrid Columns="2">
                                        <Button x:Name="btnFOdemeTamamla" Click="btnFOdemeTamamla_Click" Style="{StaticResource MaterialDesignRaisedButton}" Background="GreenYellow" Height="50" Margin="0,10,0,0" materialDesign:ButtonAssist.CornerRadius="25">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="CashCheck" VerticalAlignment="Center" Width="24" Height="24"/>
                                                <TextBlock Text="Ödeme Yap" Margin="8,0,0,0" VerticalAlignment="Center" FontWeight="Bold" FontSize="14"/>
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="btnFBorcTamamla" Click="btnFBorcTamamla_Click" Style="{StaticResource MaterialDesignRaisedButton}" Background="IndianRed" Height="50" Margin="0,10,0,0" materialDesign:ButtonAssist.CornerRadius="25">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="CashCheck" VerticalAlignment="Center" Width="24" Height="24"/>
                                                <TextBlock Text="Borç Yaz" Margin="8,0,0,0" VerticalAlignment="Center" FontWeight="Bold" FontSize="14"/>
                                            </StackPanel>
                                        </Button>
                                    </UniformGrid>
                                </StackPanel>
                            </Grid>
                        </materialDesign:Card>
                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="15,0">
                    <Button x:Name="btnFirmaEkle" Click="btnFirmaEkle_Click" Height="60" materialDesign:ButtonAssist.CornerRadius="30" Style="{StaticResource MaterialDesignRaisedDarkButton}" Margin="0,10" Background="#333">
                        <StackPanel Orientation="Horizontal" Width="180">
                            <materialDesign:PackIcon Kind="Company" Width="26" Height="26" VerticalAlignment="Center"/>
                            <TextBlock Text="Firma Ekle" Margin="15,0,0,0" VerticalAlignment="Center" FontWeight="Bold" FontSize="14"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="btnFirmaSil" Click="btnFirmaSil_Click" Height="60" materialDesign:ButtonAssist.CornerRadius="30" Style="{StaticResource MaterialDesignRaisedDarkButton}" Margin="0,10" Background="#C62828">
                        <StackPanel Orientation="Horizontal" Width="180">
                            <materialDesign:PackIcon Kind="Company" Width="26" Height="26" VerticalAlignment="Center"/>
                            <TextBlock Text="Firma Sil" Margin="15,0,0,0" VerticalAlignment="Center" FontWeight="Bold" FontSize="14"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="btnFirmaGuncelle" Click="btnFirmaGuncelle_Click" Height="60" materialDesign:ButtonAssist.CornerRadius="30" Style="{StaticResource MaterialDesignRaisedDarkButton}" Margin="0,10" Background="#1565C0">
                        <StackPanel Orientation="Horizontal" Width="180">
                            <materialDesign:PackIcon Kind="Company" Width="26" Height="26" VerticalAlignment="Center"/>
                            <TextBlock Text="Firma Güncelle" Margin="15,0,0,0" VerticalAlignment="Center" FontWeight="Bold" FontSize="14"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="btnYenile" Click="btnYenile_Click" Height="65" materialDesign:ButtonAssist.CornerRadius="32" Style="{StaticResource MaterialDesignRaisedDarkButton}" Margin="0,8" Background="#455A64">
                        <StackPanel Orientation="Horizontal" Width="190">
                            <materialDesign:PackIcon Kind="Refresh" Width="26" Height="26" VerticalAlignment="Center"/>
                            <TextBlock Text="Ekranı Yenile" Margin="15,0,0,0" VerticalAlignment="Center" FontWeight="Bold" FontSize="14"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="btnDetay" Click="btnDetay_Click" Height="65" materialDesign:ButtonAssist.CornerRadius="32" Style="{StaticResource MaterialDesignRaisedDarkButton}" Margin="0,8" Background="#455A64">
                        <StackPanel Orientation="Horizontal" Width="190">
                            <materialDesign:PackIcon Kind="Details" Width="26" Height="26" VerticalAlignment="Center"/>
                            <TextBlock Text="Detaylar" Margin="15,0,0,0" VerticalAlignment="Center" FontWeight="Bold" FontSize="14"/>
                        </StackPanel>
                    </Button>

                    <Separator Margin="25,20" Background="White" Opacity="0.6"/>
                    <Button x:Name="btnTemizle" Click="btnTemizle_Click" Height="60" materialDesign:ButtonAssist.CornerRadius="30" Style="{StaticResource MaterialDesignRaisedDarkButton}" Margin="0,10" Background="#555">
                        <StackPanel Orientation="Horizontal" Width="180">
                            <materialDesign:PackIcon Kind="DeleteSweep" Width="26" Height="26" VerticalAlignment="Center"/>
                            <TextBlock Text="Ekranı Temizle" Margin="15,0,0,0" VerticalAlignment="Center" FontWeight="Bold" FontSize="14"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </ContentControl>
    </Border>
</UserControl>
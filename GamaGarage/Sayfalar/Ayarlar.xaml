<UserControl x:Class="GamaGarage.Sayfalar.Ayarlar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes" 
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="600">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Border CornerRadius="25" Width="500" MinHeight="850">
                <Border.Background>
                    <LinearGradientBrush x:Name="AnaGradyanFirca" StartPoint="0,0" EndPoint="1,1">
                        <GradientStop x:Name="AnaStop1" Color="OrangeRed" Offset="0.0"/>
                        <GradientStop x:Name="AnaStop2" Color="LightGray" Offset="0.5"/>
                        <GradientStop x:Name="AnaStop3" Color="SteelBlue" Offset="1.0"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" Direction="0" RenderingBias="Quality" ShadowDepth="1" Opacity="0.2"/>
                </Border.Effect>
            </Border>

            <StackPanel Width="450" HorizontalAlignment="Center" Margin="0,20">
                <materialDesign:PackIcon Kind="Settings" Width="40" Height="40" HorizontalAlignment="Center" Foreground="White" Margin="0,0,0,5"/>
                <TextBlock Text="SİSTEM AYARLARI" HorizontalAlignment="Center" FontSize="24" FontWeight="ExtraBold" Foreground="White" Margin="0,0,0,15"/>

                <materialDesign:Card x:Name="cardKullaniciYonetimi" Padding="20" UniformCornerRadius="25" Background="Transparent" Margin="0,0,0,15">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <materialDesign:PackIcon Kind="AccountEdit" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="SteelBlue"/>
                            <TextBlock Text="Kullanıcı Bilgilerini Düzenle" FontSize="16" FontWeight="Bold" Foreground="#333"/>
                        </StackPanel>

                        <ComboBox x:Name="cmbKullaniciSec" materialDesign:HintAssist.Hint="Düzenlenecek Kullanıcıyı Seçin" 
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}" Margin="0,5"
                                  materialDesign:TextFieldAssist.TextFieldCornerRadius="15"
                                  SelectionChanged="CmbKullaniciSec_SelectionChanged" DisplayMemberPath="KAD" SelectedValuePath="ID"/>

                        <Grid Margin="0,10">
                            <Ellipse x:Name="ellFoto" Width="80" Height="80" Stroke="SteelBlue" StrokeThickness="2" MouseDown="imgKullaniciFoto_MouseDown" Cursor="Hand">
                                <Ellipse.Fill>
                                    <ImageBrush x:Name="imgKullaniciFoto" Stretch="UniformToFill"/>
                                </Ellipse.Fill>
                            </Ellipse>
                            <materialDesign:PackIcon Kind="Camera" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="60,0,0,0" Foreground="SteelBlue" Width="20" Height="20"/>
                        </Grid>

                        <TextBox x:Name="txtDuzenleKadi" materialDesign:HintAssist.Hint="Kullanıcı Adı" Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,5" materialDesign:TextFieldAssist.TextFieldCornerRadius="15"/>

                        <Grid Margin="0,5" Height="50">
                            <PasswordBox x:Name="txtDuzenleSifre" materialDesign:HintAssist.Hint="Yeni Şifre (Değişmeyecekse Boş Bırakın)" Style="{StaticResource MaterialDesignOutlinedPasswordBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="15" VerticalContentAlignment="Center" Padding="10,0,45,0"/>
                            <TextBox x:Name="txtSifreAcik" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="15" VerticalContentAlignment="Center" Padding="10,0,45,0" Visibility="Collapsed" IsReadOnly="True"/>
                            <ToggleButton x:Name="btnSifreGoster" Style="{StaticResource MaterialDesignActionToggleButton}" Content="{materialDesign:PackIcon Kind=EyeOff}" materialDesign:ToggleButtonAssist.OnContent="{materialDesign:PackIcon Kind=Eye}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0" Width="30" Height="30" PreviewMouseDown="btnSifreGoster_PreviewMouseDown" PreviewMouseUp="btnSifreGoster_PreviewMouseUp"/>
                        </Grid>

                        <ComboBox x:Name="cmbYetki" materialDesign:HintAssist.Hint="Yetki Seviyesi"  IsEditable="True" Style="{StaticResource MaterialDesignOutlinedComboBox}" Margin="0,5" materialDesign:TextFieldAssist.TextFieldCornerRadius="15">
                           
                        </ComboBox>

                        <StackPanel Margin="0,15,0,0">
                            <Button x:Name="btnGuncelle" Click="btnGuncelle_Click" Height="45" materialDesign:ButtonAssist.CornerRadius="22" Background="LawnGreen" BorderBrush="#4CAF50" Foreground="Black" Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ContentSaveCheck" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Text="DEĞİŞİKLİKLERİ KAYDET" FontWeight="Bold"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="btnKullaniciSil" Click="btnKullaniciSil_Click" Height="45" materialDesign:ButtonAssist.CornerRadius="22" Background="#FF5252" BorderBrush="Transparent" Foreground="White">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="AccountCancel" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Text="KULLANICIYI PASİF YAP" FontWeight="Bold"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </materialDesign:Card>

                <materialDesign:Card Padding="20" UniformCornerRadius="25" Background="Transparent">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Palette" VerticalAlignment="Center" Margin="0,0,10,0" 
                                         Foreground="{StaticResource GamaIkincilRenk}"/>

                                <TextBlock Text="Görünüm ve Renk Ayarları" FontSize="16" FontWeight="Bold" 
                           Foreground="{StaticResource GamaYaziRengi}"/>
                            </StackPanel>

                            <Button Content="Sıfırla" HorizontalAlignment="Right" 
                    Style="{StaticResource MaterialDesignFlatButton}" 
                    Foreground="{StaticResource 10}" Click="BtnOrijinalRenk_Click" 
                    Height="30" Padding="0"/>
                        </Grid>

                        <UniformGrid Columns="2">
                            <StackPanel Margin="5">
                                <TextBlock Text="Üst Renk" HorizontalAlignment="Center" Margin="0,0,0,5" FontWeight="SemiBold"
                           Foreground="{StaticResource GamaYaziRengi}"/>
                                <materialDesign:ColorPicker x:Name="cpColor1" 
                                            Background="{StaticResource 9}" 
                                            Color="{Binding Color, Source={StaticResource GamaAnaRenk}}"
                                            Height="120" Width="120"/>
                            </StackPanel>

                            <StackPanel Margin="5">
                                <TextBlock Text="Alt Renk" HorizontalAlignment="Center" Margin="0,0,0,5" FontWeight="SemiBold"
                           Foreground="{StaticResource GamaYaziRengi}"/>
                                <materialDesign:ColorPicker x:Name="cpColor3" 
                                            Color="{Binding Color, Source={StaticResource 6}}" 
                                            Height="120" Width="120"/>
                            </StackPanel>
                        </UniformGrid>

                        <Button x:Name="btnRenkUygula" Click="btnRenkUygula_Click" Height="45" Margin="0,15,0,0" 
                materialDesign:ButtonAssist.CornerRadius="22" 
                Background="{StaticResource GamaAnaRenk}" 
                Foreground="{StaticResource GamaBeyaz}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Brush" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="RENKLERİ UYGULA" FontWeight="Bold"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </materialDesign:Card>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
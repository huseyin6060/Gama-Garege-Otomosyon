<UserControl x:Class="GamaGarage.Sayfalar.MusteriSayfasi"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:Veriler="clr-namespace:GamaGarage.Veriler"
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="1600">

    <Border CornerRadius="35" ClipToBounds="True" Margin="5" >
        <ContentControl x:Name="SayfaMDetay">
            <Grid>


                <Grid Margin="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="420"/>
                        <ColumnDefinition Width="230"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" Margin="0,0,15,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <materialDesign:Card Grid.Row="0" Margin="0,0,0,12" materialDesign:ElevationAssist.Elevation="Dp3" UniformCornerRadius="25" Padding="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="LightGray" CornerRadius="25,25,0,0" Padding="10">
                                    <UniformGrid Columns="4">
                                        <TextBox x:Name="txtMusteriAra1" TextChanged="txtMusteriAra1_TextChanged" materialDesign:HintAssist.Hint="Ad veya Plaka ile Ara..." Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="20" Background="LightGray" Margin="5,0"/>


                                        <DatePicker x:Name="dpBaslangicFiltre1" Grid.Column="1" Margin="5,0" Background="#ADD8E6" materialDesign:TextFieldAssist.TextFieldCornerRadius="15" materialDesign:HintAssist.Hint="Başlangıç"/>

                                        <DatePicker x:Name="dpBitisFiltre1" Grid.Column="1" Margin="5,0" Background="#ADD8E6" materialDesign:TextFieldAssist.TextFieldCornerRadius="15" materialDesign:HintAssist.Hint="Bitiş"/>



                                        <Button x:Name="btnFiltrele1"   Click="btnFiltrele1_Click" Content="Filtrele" Style="{StaticResource MaterialDesignRaisedButton}" materialDesign:ButtonAssist.CornerRadius="18" Margin="5,0" Background="SteelBlue" Height="45" Foreground="LightGray" />
                                    </UniformGrid>
                                </Border>

                                <DataGrid x:Name="dgMusteriListesi"  Grid.Row="1"   Background="White"  BorderThickness="0"  Margin="5" AutoGenerateColumns="True"  IsReadOnly="True"   SelectionMode="Single" SelectionChanged="dgMusteriListesi_SelectionChanged" SelectionUnit="FullRow" AutoGeneratedColumns="dgMusteriListesi_AutoGeneratedColumns"/>


                            </Grid>
                        </materialDesign:Card>

                        <materialDesign:Card Grid.Row="1" materialDesign:ElevationAssist.Elevation="Dp3" UniformCornerRadius="25" Padding="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="LightGray" CornerRadius="25,25,0,0" Padding="10">
                                    <UniformGrid Columns="4">
                                        <TextBox x:Name="txtMusteriAra2"  TextChanged="txtMusteriAra2_TextChanged"  materialDesign:HintAssist.Hint="Ödeme Ara..." Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="20" Background="LightGray" Margin="5,0"/>

                                        <DatePicker x:Name="dpBaslangicFiltre2" Grid.Column="1" Margin="5,0" Background="#ADD8E6" materialDesign:TextFieldAssist.TextFieldCornerRadius="15" materialDesign:HintAssist.Hint="Başlangıç"/>

                                        <DatePicker x:Name="dpBitisFiltre2" Grid.Column="1" Margin="5,0" Background="#ADD8E6" materialDesign:TextFieldAssist.TextFieldCornerRadius="15" materialDesign:HintAssist.Hint="Bitiş"/>




                                        <Button x:Name="btnFiltrele2" Click="btnFiltrele2_Click" Content="Filtrele" Style="{StaticResource MaterialDesignRaisedButton}" materialDesign:ButtonAssist.CornerRadius="18" Margin="5,0" Background="SteelBlue" Height="45" Foreground="LightGray" />
                                    </UniformGrid>
                                </Border>

                                <DataGrid x:Name="dgMusteriOdeme"  Grid.Row="1"   Background="White"  BorderThickness="0"  Margin="5" AutoGenerateColumns="True"  IsReadOnly="True"   SelectionMode="Single" SelectionChanged="dgMusteriOdeme_SelectionChanged" SelectionUnit="FullRow" AutoGeneratedColumns="dgMusteriOdeme_AutoGeneratedColumns"/>


                            </Grid>
                        </materialDesign:Card>
                    </Grid>

                    <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="5,0">
                            <materialDesign:Card Background="#F8FFFFFF" UniformCornerRadius="25" Padding="0" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" Background="#E0E0E0" CornerRadius="25,25,0,0" Height="70">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                                            <TextBlock Text="MÜŞTERİ DETAYLARI" FontWeight="Black" Foreground="SteelBlue" Margin="8,0,0,0" VerticalAlignment="Center" FontSize="20"/>
                                        </StackPanel>
                                    </Border>

                                    <StackPanel Grid.Row="1" Margin="20,15">
                                        <Ellipse x:Name="ellFoto" Width="85" Height="85" Stroke="SteelBlue" StrokeThickness="3" Margin="0,0,0,10" HorizontalAlignment="Center" MouseDown="imgMusteriFoto_MouseDown" Cursor="Hand">
                                            <Ellipse.Fill>
                                                <ImageBrush x:Name="imgMusteriFoto" Stretch="UniformToFill"/>
                                            </Ellipse.Fill>
                                        </Ellipse>
                                        <UniformGrid Columns="2">
                                            <TextBox x:Name="txtMAd" Veriler:InputKisitlayici.SadeceMetin="True" materialDesign:HintAssist.Hint="Ad" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="15" Margin="3"/>
                                            <TextBox x:Name="txtMSoyad" Veriler:InputKisitlayici.SadeceMetin="True" materialDesign:HintAssist.Hint="Soyad" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="15" Margin="3"/>
                                        </UniformGrid>
                                        <TextBox x:Name="plaka" MaxLength="12" materialDesign:HintAssist.Hint="Araç Plaka" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="15" Margin="3"/>

                                        <TextBox x:Name="txtMGmail" materialDesign:HintAssist.Hint="Gmail" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="15" Margin="3"/>
                                        <TextBox x:Name="txtMTelefon"  Veriler:InputKisitlayici.SadeceSayi="True" MaxLength="11" materialDesign:HintAssist.Hint="Telefon (05xx...)" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="15" Margin="3" />

                                        <UniformGrid Columns="2" Height="55" Width="345" Margin="5">

                                            <DatePicker x:Name="dpAlisTarihi" Grid.Column="1" Margin="2,0" Background="#ADD8E6" materialDesign:TextFieldAssist.TextFieldCornerRadius="15" materialDesign:HintAssist.Hint="Alış Tarihi"/>

                                            <DatePicker x:Name="dpTeslimTarihi" Grid.Column="1" Margin="5,0" Background="#ADD8E6" materialDesign:TextFieldAssist.TextFieldCornerRadius="15" materialDesign:HintAssist.Hint="Teslim Tarihi"/>
                                        </UniformGrid>
                                    </StackPanel>
                                </Grid>
                            </materialDesign:Card>

                            <materialDesign:Card Background="#F8FFFFFF" UniformCornerRadius="25" Padding="0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" Background="#E0E0E0" CornerRadius="25,25,0,0" Height="70">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <materialDesign:PackIcon Kind="CashMultiple" Width="50" Height="50" Foreground="DarkGreen" VerticalAlignment="Center"/>
                                            <TextBlock Text="ÖDEME DETAYLARI" FontWeight="Black" Foreground="SteelBlue" Margin="8,0,0,0" VerticalAlignment="Center" FontSize="20"/>
                                        </StackPanel>
                                    </Border>

                                    <StackPanel Grid.Row="1" Margin="20,15">
                                        <UniformGrid Columns="2">
                                            <TextBox x:Name="txtMOAD" materialDesign:HintAssist.Hint="Adı" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="12" Margin="2"  Focusable="False" IsReadOnly="True" IsHitTestVisible="False"/>
                                            <TextBox x:Name="txtMOSoyad" materialDesign:HintAssist.Hint="Soyadı" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="12" Margin="2" Focusable="False" IsReadOnly="True" IsHitTestVisible="False"/>

                                            <TextBox x:Name="txtTutar" Veriler:InputKisitlayici.SadeceSayi="True" materialDesign:HintAssist.Hint="Toplam Tutar" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="12" Margin="3" />
                                            <TextBox x:Name="txtÖdenen" Veriler:InputKisitlayici.SadeceSayi="True" materialDesign:HintAssist.Hint="Ödenen" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="12" Margin="3" />
                                            <TextBox x:Name="txtKalan" materialDesign:HintAssist.Hint="Kalan" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="12" Margin="3" IsReadOnly="True" Background="#F0F0F0"  Focusable="False"  IsHitTestVisible="False"/>

                                            <DatePicker x:Name="dpMOdemeTarih" Grid.Column="1" Margin="5,0" Background="#ADD8E6" materialDesign:TextFieldAssist.TextFieldCornerRadius="15" materialDesign:HintAssist.Hint="İşlem Tarihi"/>



                                        </UniformGrid>
                                        <TextBox x:Name="txtMAciklama" materialDesign:HintAssist.Hint="Yapılan İşlem Açıklaması" Height="80" TextWrapping="Wrap" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="15" Margin="3" AcceptsReturn="True"/>
                                        <Button x:Name="btnMOdemeTamamla" Click="btnMOdemeTamamla_Click" Style="{StaticResource MaterialDesignRaisedButton}" Background="GreenYellow" Height="50" Margin="0,10,0,0" materialDesign:ButtonAssist.CornerRadius="25">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="CashCheck" VerticalAlignment="Center" Width="24" Height="24"/>
                                                <TextBlock Text="ÖDEMEYİ KAYDET" Margin="8,0,0,0" VerticalAlignment="Center" FontWeight="Bold" FontSize="14"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </materialDesign:Card>
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="15,0">
                        <Button x:Name="btnMusteriEkle" Click="btnMusteriEkle_Click" Height="60" materialDesign:ButtonAssist.CornerRadius="30" Style="{StaticResource MaterialDesignRaisedDarkButton}" Margin="0,10" Background="#333" BorderBrush="Transparent">
                            <StackPanel Orientation="Horizontal" Width="180">
                                <materialDesign:PackIcon Kind="AccountPlus" Width="26" Height="26" VerticalAlignment="Center"/>
                                <TextBlock Text="Müşteri Ekle" Margin="15,0,0,0" VerticalAlignment="Center" FontWeight="Bold" FontSize="14"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="btnMusteriSil" Click="btnMusteriSil_Click" Height="60" materialDesign:ButtonAssist.CornerRadius="30" Style="{StaticResource MaterialDesignRaisedDarkButton}" Margin="0,10" Background="#C62828" BorderBrush="Transparent">
                            <StackPanel Orientation="Horizontal" Width="180">
                                <materialDesign:PackIcon Kind="AccountRemove" Width="26" Height="26" VerticalAlignment="Center"/>
                                <TextBlock Text="Müşteri Sil" Margin="15,0,0,0" VerticalAlignment="Center" FontWeight="Bold" FontSize="14"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="btnMusteriGuncelle" Click="btnMusteriGuncelle_Click" Height="60" materialDesign:ButtonAssist.CornerRadius="30" Style="{StaticResource MaterialDesignRaisedDarkButton}" Margin="0,10" Background="#1565C0" BorderBrush="Transparent">
                            <StackPanel Orientation="Horizontal" Width="180">
                                <materialDesign:PackIcon Kind="AccountEdit" Width="26" Height="26" VerticalAlignment="Center"/>
                                <TextBlock Text="Güncelle" Margin="15,0,0,0" VerticalAlignment="Center" FontWeight="Bold" FontSize="14"/>
                            </StackPanel>
                        </Button>


                        <Button x:Name="btnDetay" Click="btnDetay_Click" Height="65" materialDesign:ButtonAssist.CornerRadius="32" Style="{StaticResource MaterialDesignRaisedDarkButton}" Margin="0,8" Background="#455A64">
                            <StackPanel Orientation="Horizontal" Width="190">
                                <materialDesign:PackIcon Kind="Details" Width="26" Height="26" VerticalAlignment="Center"/>
                                <TextBlock Text="Detaylar" Margin="15,0,0,0" VerticalAlignment="Center" FontWeight="Bold" FontSize="14"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="btnYenile" Click="btnYenile_Click" Height="65" materialDesign:ButtonAssist.CornerRadius="32" Style="{StaticResource MaterialDesignRaisedDarkButton}" Margin="0,8" Background="#455A64" BorderBrush="Transparent">
                            <StackPanel Orientation="Horizontal" Width="190">
                                <materialDesign:PackIcon Kind="Refresh" Width="26" Height="26" VerticalAlignment="Center"/>
                                <TextBlock Text="Ekranı Yenile" Margin="15,0,0,0" VerticalAlignment="Center" FontWeight="Bold" FontSize="14"/>
                            </StackPanel>
                        </Button>
                        <Separator Margin="25,20" Background="White" Opacity="0.6"/>
                        <Button x:Name="btnTemizle" Click="btnMTemizle_Click" Height="60" materialDesign:ButtonAssist.CornerRadius="30" Style="{StaticResource MaterialDesignRaisedDarkButton}" Margin="0,10" Background="#555" BorderBrush="Transparent">
                            <StackPanel Orientation="Horizontal" Width="180">
                                <materialDesign:PackIcon Kind="DeleteSweep" Width="26" Height="26" VerticalAlignment="Center"/>
                                <TextBlock Text="Ekranı Temizle" Margin="15,0,0,0" VerticalAlignment="Center" FontWeight="Bold" FontSize="14"/>
                            </StackPanel>
                        </Button>


                    </StackPanel>
                </Grid>
            </Grid>
        </ContentControl>
    </Border>
</UserControl>
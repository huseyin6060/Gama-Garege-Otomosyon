<UserControl x:Class="GamaGarage.Anamenuler.GirisEkrani"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="550">

    <Viewbox Stretch="Uniform">
        <Grid>
            <Border Background="Transparent" CornerRadius="20" Padding="30">
                <StackPanel Width="350"> <TextBlock Text="GAMACILAR" HorizontalAlignment="Center" FontSize="26" FontWeight="Black" Foreground="Black"/>
                    <TextBlock Text="OTO SERVİS OTOMASYONU" HorizontalAlignment="Center" FontSize="16" Foreground="Black" Margin="0,5,0,30"/>

                    <TextBox x:Name="txtKullanici" materialDesign:HintAssist.Hint="Kullanıcı Adı Giriniz" 
                             Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                             Margin="0,5,0,20" Background="White" materialDesign:TextFieldAssist.TextFieldCornerRadius="15"/>

                    <PasswordBox x:Name="txtSifre" materialDesign:HintAssist.Hint="Şifre Giriniz" 
                                 Style="{StaticResource MaterialDesignOutlinedPasswordBox}" 
                                 Margin="0,5,0,30" Background="White" materialDesign:TextFieldAssist.TextFieldCornerRadius="15"/>

                    <Button x:Name="btnGirisYap" Click="btnGirisYap_Click" Content="GİRİŞ" 
                            Height="55" materialDesign:ButtonAssist.CornerRadius="25"
                            Background="Transparent" BorderBrush="Black" BorderThickness="2" 
                            Foreground="Black" FontSize="16" FontWeight="Bold"/>
                </StackPanel>
            </Border>
        </Grid>
    </Viewbox>
</UserControl>